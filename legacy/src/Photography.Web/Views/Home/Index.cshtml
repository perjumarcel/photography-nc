@using Photography.Album.Dto
@using Photography.Web.Helpers
@model Photography.Web.Models.Home.HomeViewModel
@{
    ViewBag.CurrentPageName = PageNames.Frontend.Home; // The menu item will be active for this page.
}

@section styles {
    <meta property="og:title" content="Nicolae Covercenco Photography" />
    @{
        AlbumListItemDto album = Model.Albums.FirstOrDefault();
        if (album != null)
        {
            <meta property="og:image" content="@Url.Content(album.CoverUrl, true)" />
        }
        else
        {
            <meta property="og:image" content="@Url.Content(AlbumListItemDto.DefaultCoverUrl, true)" />
        }
    }
}

<!--=============== Content ===============-->
<div class="content full-height">
    <div class="resize-carousel-holder">
        <div id="gallery_horizontal" class="gallery_horizontal">
            @foreach (var album in Model.Albums)
            {
                <div class="horizontal_item">
                    <div class="overlay"></div>
                    @*<div class="zoomimage"><i class="fa fa-expand"></i></div>*@
                    <img class="lazy" src="@Url.Content(album.CoverUrl)?width=200" data-src="@Url.Content(album.CoverUrl)?width=2000">
                    <div class="port-desc-holder">
                        <div class="port-desc">
                            <div class="grid-item">
                                <h3><a href="@Url.Action("Details", "Portfolio", new{ id = album.Id })">@album.Title</a></h3>
                                <span>@album.Category</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        <!--  navigation -->
        <div class="customNavigation">
            <a class="next-slide transition"><i class="fa fa-angle-right"></i></a>
            <a class="prev-slide transition"><i class="fa fa-angle-left"></i></a>
        </div>
        <!--  navigation end-->
    </div>
</div>
<!-- Content end  --> 	