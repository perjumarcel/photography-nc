@{
    ViewBag.CurrentPageName = PageNames.Frontend.Portfolio;
}
@using Photography.Album.Dto
@using Photography.Entities
@using Photography.Web.Helpers
@model Photography.Web.Models.Portfolio.AlbumViewModel

@section styles
{
    <link href="~/lib/gridzy/gridzy-2.0.min.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/lib/gridzy/skins/gridzySkinBlur/style.min.css" rel="stylesheet" asp-append-version="true" />

    <meta property="og:title" content="Nicolae Covercenco - @(Model.Album.Title)" />
    <meta property="og:image" content="@Url.Content(Model.Images.Where(x=>x.ImageType == ImageType.Cover).Select(x => x.RelativeUrl).FirstOrDefault() ?? AlbumListItemDto.DefaultCoverUrl, true)" />
}

@section scripts
{
    <script src="~/lib/gridzy/gridzy-2.0.min.js" asp-append-version="true"></script>
    <script src="~/lib/waitForImages/dist/jquery.waitforimages.min.js" asp-append-version="true"></script>
    <script src="~/lib/skrollr/dist/skrollr.min.js" asp-append-version="true"></script>
}

<div class="show-hid-content ishid" style="z-index: 101;">Description <i class="fa fa-long-arrow-down"></i></div>
<!--=============== description column  ===============-->
<div class="fixed-info-container hidden-column" style="z-index: 100;">
    <h3>@Model.Album.Title</h3>
    <div class="separator"></div>
    <div class="clearfix"></div>
    <p>@Model.Album.Description</p>
    <h4>Info</h4>
    <ul class="project-details">
        <li>
            <i class="fa fa-bicycle"></i>
            <div class="pd-holder">
                <h5>Category: <a href="#">@Model.Album.Category</a></h5>
            </div>
        </li>

        @if (Model.Album.EventDate.HasValue)
        {
            <li>
                <i class="fa fa-calendar"></i>
                <div class="pd-holder">
                    <h5>Date: @Model.Album.EventDate.Value.ToString("MMMM yyyy")</h5>
                </div>
            </li>
        }

        @if (!string.IsNullOrEmpty(Model.Album.Client))
        {
            <li>
                <i class="fa fa-paw"></i>
                <div class="pd-holder">
                    <h5>Client: @Model.Album.Client</h5>
                </div>
            </li>
        }

        @if (!string.IsNullOrEmpty(Model.Album.Location))
        {
            <li>
                <i class="fa fa-map-o"></i>
                <div class="pd-holder">
                    <h5>Location:  @Model.Album.Location</h5>
                </div>
            </li>
        }

    </ul>
    <div class="content-nav">
        <ul>
            <li><a href="@Url.Action("Previous", "Portfolio", new {albumId = Model.Album.Id })"><i class="fa fa-long-arrow-left"></i></a></li>
            <li><span>/</span></li>
            <li><a href="@Url.Action("Next", "Portfolio", new {albumId = Model.Album.Id })"><i class="fa fa-long-arrow-right"></i></a></li>
        </ul>
        <div class="p-all">
            <a href="@Url.Action("Index", "Portfolio")"><i class="fa fa-th-large"></i></a>
        </div>
    </div>
</div>


<!-- Page title section -->
<section class="parallax-section">
    <div class="overlay"></div>
    <div class="bg" style="background-image: url(@Url.Content(Model.Images.Where(x=>x.ImageType == ImageType.Cover).Select(x => x.RelativeUrl).FirstOrDefault() ?? AlbumListItemDto.DefaultCoverUrl))" data-top-bottom="transform: translateY(200px);" data-bottom-top="transform: translateY(-200px);"></div>
    <div class="container">
        <h2>@Model.Album.Title</h2>
    </div>
    <a class="custom-scroll-link sect-scroll" href="#sec1"><i class="fa fa-angle-double-down"></i></a>
</section>
<section id="sec1">
    <div class="container column-container">
        <div class="row">
            <!-- project images -->
            <div class="col-md-12">
                <div class="gridzy gridzySkinBlur" data-gridzy-spaceBetween="50" data-gridzy-desiredHeight="500" style="margin-bottom: 50px;">
                    @foreach (var image in Model.Images)
                    {
                        <img class="gridzyImage" data-gridzylazysrc="@Url.Content(image.RelativeUrl)" height="@image.Height" width="@image.Width" alt="@image.OriginalName" />
                    }
                </div>
                <div class="project-box">
                    <div class="content-nav">
                        <ul>
                            <li><a href="@Url.Action("Previous", "Portfolio", new {albumId = Model.Album.Id })"><i class="fa fa-long-arrow-left"></i></a></li>
                            <li><span>/</span></li>
                            <li><a href="@Url.Action("Next", "Portfolio", new {albumId = Model.Album.Id })"><i class="fa fa-long-arrow-right"></i></a></li>
                        </ul>
                        <div class="p-all">
                            <a href="@Url.Action("Index", "Portfolio")"><i class="fa fa-th-large"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>