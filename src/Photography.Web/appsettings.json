{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=photography;Username=postgres;Password=postgres"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  },
  "Jwt": {
    "Issuer": "photography-api",
    "Audience": "photography-client",
    "Key": "",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 14
  },
  "Storage": {
    "Provider": "Local",
    "Local": {
      "RootPath": "./_storage",
      "PublicBaseUrl": "/local-storage"
    },
    "R2": {
      "ServiceUrl": "",
      "Bucket": "",
      "AccessKey": "",
      "SecretKey": "",
      "PublicBaseUrl": "",
      "Region": "auto"
    }
  }
}
